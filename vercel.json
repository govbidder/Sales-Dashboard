{
  "functions": {
    "app/api/**": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/generate-recurring",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/email-digest",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/monthly-report",
      "schedule": "0 10 1 * *"
    }
  ]
}
