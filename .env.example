# ═══════════════════════════════════════════════════════════════════════════
# GovBidder Sales Dashboard — Variables de entorno
#
# Copiá este archivo a `.env.local` y reemplazá los placeholders con tus valores.
# `.env.local` está en `.gitignore` — los secrets nunca se commitean.
#
# Para producción: pegá los mismos valores en Vercel → Settings → Environment
# Variables (no se sincroniza con .env.local automáticamente).
# ═══════════════════════════════════════════════════════════════════════════


# ─── Supabase (REQUERIDAS) ──────────────────────────────────────────────────
# Project URL: Supabase Dashboard → Settings → Data API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key (público, OK que esté en el browser): Settings → API Keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Service role key (SECRET, solo server-side): Settings → API Keys → service_role
# Tiene permisos de admin sobre toda la DB — NUNCA exponerla al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_jwt_here


# ─── Anthropic (REQUERIDA si querés AI Assistant, Standup, Extract, Suggest) ──
# Generar en https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here


# ─── Resend (OPCIONAL — solo si querés email digest diario) ──────────────────
# Sin esto, el cron de email-digest se salta silenciosamente y todo lo demás
# funciona igual. Para configurar:
#   1. Crear cuenta en https://resend.com
#   2. Verificar dominio (Settings → Domains → Add) — agregás 3 DNS records
#   3. Crear API key en https://resend.com/api-keys
#   4. Pegar abajo
RESEND_API_KEY=re_your_key_here

# Email "From" para los digests. Hasta verificar dominio, usá onboarding@resend.dev
# Una vez verificado govbidder.com, podés usar notifications@govbidder.com.
RESEND_FROM=GovBidder <onboarding@resend.dev>


# ─── Cron secret (OPCIONAL — solo Vercel) ────────────────────────────────────
# Token que protege los endpoints /api/cron/* de ser invocados por terceros.
# Generar con:    openssl rand -base64 32 | pbcopy
# Sin esto, los crons funcionan igual pero CUALQUIERA puede invocarlos
# (no es ideal, pero no rompe nada).
CRON_SECRET=tu_token_random_largo_aca


# ─── App URL (OPCIONAL — usado en email templates) ───────────────────────────
# Sin esto, los emails usan https://sales-dashboard-zeta-rose.vercel.app por default.
NEXT_PUBLIC_APP_URL=https://sales-dashboard-zeta-rose.vercel.app
